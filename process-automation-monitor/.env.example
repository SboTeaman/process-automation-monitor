# ─── PostgreSQL (orchestrator-service) ───────────────────────────────────────
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orchestrator_db

# ─── MySQL (worker-service) ───────────────────────────────────────────────────
MYSQL_USER=worker
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=worker_db

# ─── MySQL (analytics-service) ────────────────────────────────────────────────
MYSQL_ANALYTICS_USER=analytics
MYSQL_ANALYTICS_PASSWORD=changeme
MYSQL_ANALYTICS_ROOT_PASSWORD=changeme_root
MYSQL_ANALYTICS_DATABASE=analytics_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-32-chars
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Service URLs (used by Docker Compose internal networking) ────────────────
WORKER_SERVICE_URL=http://worker-service:8000
ORCHESTRATOR_DB_URL=postgresql://orchestrator:changeme@postgres:5432/orchestrator_db
ANALYTICS_DB_URL=mysql+pymysql://analytics:changeme@mysql-analytics:3306/analytics_db
