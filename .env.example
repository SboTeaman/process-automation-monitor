# ============================================================================
# Process Automation Monitor - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to git - it contains secrets.
# ============================================================================

# ─── PostgreSQL (Orchestrator Database) ──────────────────────────────────
POSTGRES_DB=orchestrator_db
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme_postgres_dev_only

# ─── MySQL (Worker Database) ─────────────────────────────────────────────
MYSQL_DATABASE=worker_db
MYSQL_USER=worker
MYSQL_PASSWORD=changeme_mysql_worker_dev_only
MYSQL_ROOT_PASSWORD=changeme_mysql_root_dev_only

# ─── MySQL (Analytics Database) ──────────────────────────────────────────
MYSQL_ANALYTICS_DATABASE=analytics_db
MYSQL_ANALYTICS_USER=analytics
MYSQL_ANALYTICS_PASSWORD=changeme_mysql_analytics_dev_only
MYSQL_ANALYTICS_ROOT_PASSWORD=changeme_mysql_analytics_root_dev_only

# ─── JWT & Authentication ───────────────────────────────────────────────
# Generate random secrets: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Service-to-Service Authentication ──────────────────────────────────
# Generate random keys: openssl rand -base64 32
WORKER_API_KEY=change_me_generate_with_openssl_rand_base64_32
ANALYTICS_API_KEY=change_me_generate_with_openssl_rand_base64_32

# ─── Frontend Configuration ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Email / SMTP Configuration (Optional) ──────────────────────────────
# Leave empty to disable email features
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Application Profiles ───────────────────────────────────────────────
# Use 'docker' for Docker Compose, 'dev' for local development
SPRING_PROFILES_ACTIVE=docker

# ─── Swagger / OpenAPI Documentation ───────────────────────────────────
SWAGGER_ENABLED=false

# ─── Service URLs ──────────────────────────────────────────────────────
WORKER_SERVICE_URL=http://worker-service:8000

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate secrets: openssl rand -base64 32
# 3. Update .env with your values
# 4. Start Docker: docker-compose up -d
# 5. Frontend: http://localhost:3000
# 6. API: http://localhost:8080/api/
# ============================================================================
